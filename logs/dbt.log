        when deltas.month_ending_arr > 0 then 'Active'
        when deltas.churn_arr < 0 then 'Churned'
        else 'Pipeline Only'
    end as customer_status
from DEMO_AGENTS_DAVID.intermediate.int_account_monthly_deltas deltas
